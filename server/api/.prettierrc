{
    "endOfLine": "auto",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",
    "arrowParens": "always",
    "printWidth": 120,
    "useTabs": false,
    "bracketSpacing": true,
    "bracketSameLine": true,
    "requirePragma": false,
    "insertPragma": false,
    "proseWrap": "always"
}
