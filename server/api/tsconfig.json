{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "rootDir": ".",
        "outDir": "dist",
        "paths": {
            "@/*": ["./*"],
            "@shared/*": ["../../shared/*"]
        }
    },
    "include": ["src/**/*.ts", "types"],
    "references": [{ "path": "../../shared" }]
}
