    "type": "commonjs",
    "main": "index.js",
    "scripts": {
        "dev": "npx tsx watch --exclude node_modules --include src src/index.ts",
        "dev:remote": "npx ngrok http --url=nongraven-stedfastly-galilea.ngrok-free.dev 8000 --config ngrok.yaml",
        "start": "npx pm2 start src/index.ts --name discord-bot-api --interpreter tsx",
        "stop": "npx pm2 stop discord-bot-api",
        "restart": "npx pm2 restart discord-bot-api --update-env",
        "logs": "npx pm2 logs discord-bot-api --lines 50",
        "prod": "npx pm2 start src/index.ts --name discord-bot-api --watch --no-daemon --interpreter tsx"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.108.2",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "pg": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.3",
        "@types/pg": "^8.20.0",
        "supabase": "^2.109.0",
        "tsx": "^4.23.0"
    }
}
